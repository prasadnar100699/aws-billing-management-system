# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node.js dependencies for frontend
frontend/node_modules/
frontend/.pnp
frontend.pnp.js

# Node.js dependencies for backend (if any exist, e.g., in case you're using Node.js for some part of the backend)
backend/node_modules/
backend/.pnp
backend.pnp.js

# Python virtual environment for the backend
backend/venv/

# Testing files
coverage/

# Next.js build output
frontend/.next/
frontend/out/

# Backend build or production output (if any, like Python build files)
backend/build

# Log files
backend/logs/

# IDE or editor config files
.vscode/
.idea/

# Miscellaneous system files
.DS_Store
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local environment configuration files (e.g., .env files)
*.env
*.env.local
*.env.*.local

# Vercel deployment config
.vercel/

# TypeScript build info
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Other untracked files
*.pem

# Docker configuration (if any)
.docker
.env
